# =====================================================================
# TRACÉA — exemple de configuration .env
# =====================================================================
# Ce fichier sert de référence pour les variables d'environnement
# requises par TRACÉA. Ne mettre AUCUNE valeur réelle ici.
#
# Pour le développement local, copier ce fichier vers `.env.local`
# (ignoré par git via .gitignore) et y renseigner les valeurs propres
# à votre environnement. En production (Vercel), définir les mêmes
# variables dans le tableau de bord du projet.
# =====================================================================

# ---------------------------------------------------------------------
# Supabase (base de données + authentification)
# ---------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role : utilisée uniquement côté serveur, jamais exposée client.
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------
# Anthropic (génération IA des miroirs et résumés)
# ---------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------
# ElevenLabs (génération offline d'assets audio — build time uniquement)
# ---------------------------------------------------------------------
ELEVENLABS_API_KEY=

# ---------------------------------------------------------------------
# Bêta — mot de passe d'activation manuelle de is_beta_tester
# ---------------------------------------------------------------------
BETA_PASSWORD=

# ---------------------------------------------------------------------
# Stripe — mode dormant tant que STRIPE_ENABLED=false
# ---------------------------------------------------------------------
# Double drapeau :
#   - STRIPE_ENABLED              : drapeau SERVEUR. Lu par les routes
#                                   /api/subscribe et /api/stripe/webhook.
#                                   Bloque toute initialisation Stripe et
#                                   toute écriture DB tant qu'il n'est pas
#                                   à "true".
#   - NEXT_PUBLIC_STRIPE_ENABLED  : drapeau UI (futur). Sera lu par
#                                   /app/subscribe et /app/profil pour
#                                   afficher ou masquer les boutons de
#                                   souscription, de gestion d'abonnement
#                                   et de résiliation.
#
# Tant que les DEUX ne sont pas à "true", aucun paiement ne doit être
# visible, aucun checkout ne doit être cliquable, aucun gating testeur
# ne doit être modifié.
#
# Les variables sensibles ci-dessous (STRIPE_SECRET_KEY,
# STRIPE_WEBHOOK_SECRET) ne doivent JAMAIS être préfixées par
# NEXT_PUBLIC_ : ce sont des secrets serveur. Les préfixer NEXT_PUBLIC_
# les exposerait dans le bundle client, ce qui constitue une fuite de
# secret.
STRIPE_ENABLED=false
NEXT_PUBLIC_STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY_ID=
STRIPE_PRICE_YEARLY_ID=
# Optionnel — identifiant de configuration custom du Stripe Billing
# Portal (laisser vide pour utiliser la config par défaut Stripe).
STRIPE_PORTAL_CONFIG_ID=

# ---------------------------------------------------------------------
# Resend (envoi d'emails transactionnels)
# ---------------------------------------------------------------------
RESEND_API_KEY=

# ---------------------------------------------------------------------
# Cron secret (protège les routes cron Vercel)
# ---------------------------------------------------------------------
CRON_SECRET=

# ---------------------------------------------------------------------
# URL canonique de l'application (success_url / cancel_url Stripe, etc.)
# ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------
# Test local (optionnel)
# ---------------------------------------------------------------------
# Si TEST_LOCAL=true, /api/tracea final-analysis renvoie un texte
# simulé sans appeler Anthropic. Utile pour les tests sans coût IA.
TEST_LOCAL=
